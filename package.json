{
  "name": "nextrepexpo",
  "version": "2.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app components constants db hooks lib scripts",
    "test": "vitest run",
    "check:arch": "node scripts/check-architecture.mjs",
    "check": "npm run check:arch && npm run typecheck && npm run lint && npm run test",
    "eas-build-post-install": "node -e \"if(process.platform==='linux'){require('child_process').execSync('npm install --no-save lightningcss-linux-x64-gnu@1.27.0',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
